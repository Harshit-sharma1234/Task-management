│   │   ├── ProjectCalendar.jsx     # Calendar view with due dates
│   │   ├── ProjectSettings.jsx
│   │   ├── ProjectTask.jsx         # Task list + status update + delete
│   │   ├── Sidebar.jsx
│   │   ├── StatsGrid.jsx           # Dashboard stat cards
│   │   ├── TaskSummary.jsx         # Right sidebar task summary
│   │   ├── WorkspaceDropdown.jsx   # Org switcher
